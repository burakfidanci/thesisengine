# Core symbol and runtime
SYMBOL=ASELS
SYMBOL_YAHOO=ASELS.IS
DATA_DELAY_MINUTES=15

# Cloudflare storage
# Pages/Worker binding name must be SIGNAL_KV.
# Set the actual KV namespace id in wrangler.toml, not here.

# OpenAI
# Store real value with: npx wrangler secret put OPENAI_API_KEY
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# News
GOOGLE_NEWS_RSS_URL=https://news.google.com/rss/search?q=ASELS

# Market context
XU100_SYMBOL=XU100.IS

# Order-flow / order book
# Enable only when your provider includes licensed BIST order-book data.
ORDER_FLOW_ENABLED=false

# Production smoke test
SMOKE_BASE_URL=
SMOKE_REQUIRE_SIGNAL=true
